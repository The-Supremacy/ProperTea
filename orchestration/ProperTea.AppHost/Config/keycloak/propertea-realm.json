{
  "realm": "propertea",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "organizationsEnabled": true,
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "landlord-bff",
      "name": "Landlord BFF",
      "description": "Confidential OIDC client for the Landlord Portal backend-for-frontend.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "landlord-bff-secret",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:*",
        "https://localhost:*"
      ],
      "webOrigins": ["+"],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "organization",
        "offline_access",
        "address",
        "phone",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "propertea-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "propertea-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
            "name": "organization",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-organization-membership-mapper",
            "consentRequired": false,
            "config": {
                "introspection.token.claim": "true",
                "multivalued": "true",
                "userinfo.token.claim": "true",
                "addOrganizationAttributes": "false",
                "id.token.claim": "true",
                "lightweight.claim": "false",
                "access.token.claim": "true",
                "claim.name": "organization",
                "jsonType.label": "String",
                "addOrganizationId": "true"
            }
        }
      ]
    },
    {
      "clientId": "organization-service",
      "name": "Organization Service",
      "description": "Confidential client for the Organization microservice. Used for token introspection and admin API calls.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "org-service-secret",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": [],
      "optionalClientScopes": []
    },
    {
      "clientId": "user-service",
      "name": "User Service",
      "description": "Confidential client for the User microservice. Used for token introspection and admin API calls.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "user-service-secret",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": [],
      "optionalClientScopes": []
    },
    {
      "clientId": "company-service",
      "name": "Company Service",
      "description": "Client for the Company microservice (JWT validation only).",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "property-service",
      "name": "Property Service",
      "description": "Client for the Property microservice (JWT validation only).",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "scalar-local",
      "name": "Scalar (Local Dev)",
      "description": "Public PKCE client for Scalar API documentation in local development.",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:*",
        "https://localhost:*"
      ],
      "webOrigins": ["+"],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "organization",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "propertea-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "propertea-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "service-account-organization-service",
      "enabled": true,
      "serviceAccountClientId": "organization-service",
      "clientRoles": {
        "realm-management": [
          "manage-realm",
          "manage-users",
          "manage-clients",
          "query-users",
          "query-clients",
          "query-realms",
          "view-realm",
          "view-users",
          "view-clients"
        ]
      }
    },
    {
      "username": "service-account-user-service",
      "enabled": true,
      "serviceAccountClientId": "user-service",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "query-users",
          "view-users"
        ]
      }
    }
  ]
}
